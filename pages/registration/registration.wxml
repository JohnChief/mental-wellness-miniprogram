<view class="page">
  <view class="page-title">报名活动</view>
  <view class="form-card card">
    <view class="event-summary">{{event.title}}</view>

    <view class="field">
      <view class="label">姓名</view>
      <input class="input" maxlength="30" placeholder="请输入报名人姓名" bindinput="onNameInput" />
    </view>

    <view class="field">
      <view class="label">手机号</view>
      <input class="input" type="number" maxlength="11" placeholder="用于活动通知与确认" bindinput="onPhoneInput" />
    </view>

    <view class="field">
      <view class="label">备注（选填）</view>
      <textarea
        class="textarea"
        maxlength="200"
        placeholder="可填写时间安排、无障碍需求等非健康敏感信息"
        bindinput="onRemarkInput"
      ></textarea>
    </view>

    <view class="agreement-row" bindtap="toggleAgreement">
      <view class="{{checkboxClass}}">{{checkboxText}}</view>
      <view class="agreement-text">
        我已阅读并同意
        <text class="link" catchtap="openPrivacy">《隐私政策》</text>
        ，同意将以上信息用于活动报名与联络。
      </view>
    </view>

    <button class="primary-button submit-button" loading="{{submitting}}" bindtap="submit">提交报名</button>
  </view>

  <view class="success-hint card">
    <view class="hint-title">提交成功后</view>
    <view class="muted">页面会显示确认提示；客服或社群二维码将在运营资料准备后补充。</view>
  </view>
</view>
