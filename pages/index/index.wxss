.brand-card {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  margin-right: 26rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  background: #7565f6;
  border-radius: 34rpx;
}

.brand-name {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.hero-card {
  min-height: 270rpx;
  margin-top: 28rpx;
  padding: 54rpx 30rpx 30rpx;
  color: #40358e;
  background: linear-gradient(135deg, #eee9ff, #e8e1ff);
  border: 1rpx solid #d9d0ff;
  border-radius: 32rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: #77718d;
  font-size: 25rpx;
}

.hero-action {
  margin-top: 76rpx;
  font-size: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.service-card {
  display: flex;
  align-items: center;
  min-height: 132rpx;
  padding: 24rpx;
  font-size: 29rpx;
  font-weight: 600;
}

.consult-card {
  margin-top: 22rpx;
  padding: 30rpx;
}

.consult-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.event-card {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.event-cover {
  width: 138rpx;
  height: 106rpx;
  flex: none;
  border-radius: 22rpx;
}

.event-content {
  min-width: 0;
  margin-left: 24rpx;
}

.event-title {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.compliance-note {
  margin: 34rpx 12rpx 0;
  color: #9995a6;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}
