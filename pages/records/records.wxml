<view class="page">
  <view class="page-title">我的报名</view>
  <view wx:if="{{loading}}" class="empty-state">正在加载...</view>
  <view wx:if="{{showEmpty}}" class="empty-state">还没有报名记录，去活动页看看吧</view>
  <view class="record card" wx:for="{{records}}" wx:key="id">
    <view class="record-head">
      <view class="record-name">{{item.event.title}}</view>
      <view class="{{item.statusClass}}">{{item.statusText}}</view>
    </view>
    <view class="muted">{{item.event.event_time_text}} · {{item.event.location}}</view>
    <view class="record-person">报名人：{{item.name}} {{item.phone}}</view>
    <button
      wx:if="{{item.canCancel}}"
      class="cancel-button"
      data-id="{{item.id}}"
      bindtap="cancel"
    >取消报名</button>
  </view>
</view>
