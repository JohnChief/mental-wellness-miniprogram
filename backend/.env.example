MYSQL_ADDRESS=127.0.0.1:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=flask_demo
# 本地快速预览可改为 DATABASE_URL=sqlite:///local.db
SECRET_KEY=replace-with-a-long-random-string
ADMIN_API_KEY=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_COOKIE_SECURE=false
WECHAT_APP_ID=your-mini-program-appid
WECHAT_APP_SECRET=your-mini-program-appsecret
AUTO_INIT_DB=true
SEED_SAMPLE_DATA=true
ALLOW_DEV_OPENID=false
